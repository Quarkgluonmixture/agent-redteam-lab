# Copy to `.env` (gitignored) and fill in as needed. NONE of these are required
# for the default local loop (`--agent deterministic` needs no keys).

# Only needed to evaluate against the hosted OpenAI target agent (`--agent openai`).
OPENAI_API_KEY=

# Portfolio selector mode for the Kaggle adapter: public_lb | private_transfer | research
ARL_MODE=public_lb

# Optional: point the helper scripts at a specific aicomp binary (e.g. a venv).
# AICOMP=aicomp
