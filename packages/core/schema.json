{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Quarkgluonmixture/agent-redteam-lab/packages/core/schema.json",
  "title": "AttackCandidateDraft",
  "description": "Language-neutral JSONL row for a replayable attack candidate. Only `userMessages` is shipped to the evaluator; all other fields are internal metadata for local selection/ranking and are never trusted for scoring.",
  "type": "object",
  "required": ["id", "userMessages", "strategyId", "intendedPredicate"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "userMessages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "type": "string", "maxLength": 10000 },
      "description": "Replayable user-turn chain. maxLength is the competition limit (10000); the local SDK wheel enforces 2000 in interact() — keep local-exploration messages <= 2000."
    },
    "strategyId": { "type": "string" },
    "intendedPredicate": {
      "type": "string",
      "enum": ["EXFILTRATION", "UNTRUSTED_TO_ACTION", "DESTRUCTIVE_WRITE", "CONFUSED_DEPUTY", "UNKNOWN"]
    },
    "templateId": { "type": ["string", "null"] },
    "expectedTools": { "type": "array", "items": { "type": "string" } },
    "expectedSink": { "type": ["string", "null"] },
    "expectedSource": { "type": ["string", "null"] },
    "syntheticScenarioId": { "type": ["string", "null"] },
    "estimatedReplayMs": { "type": ["number", "null"] },
    "estimatedTokens": { "type": ["integer", "null"] },
    "estimatedCostUsd": { "type": ["number", "null"] },
    "publicCellKey": { "type": ["string", "null"] },
    "coarseCellKey": { "type": ["string", "null"] },
    "localReplaySuccess": { "type": ["boolean", "null"] },
    "deterministicSuccess": { "type": ["boolean", "null"] },
    "gptOssSuccess": { "type": ["boolean", "null"] },
    "gemmaSuccess": { "type": ["boolean", "null"] },
    "severityWeight": { "type": ["integer", "null"], "enum": [1, 2, 4, 8, 16, null] },
    "expectedScore": { "type": ["number", "null"] },
    "scorePerSecond": { "type": ["number", "null"] },
    "graderRisk": { "type": ["number", "null"] },
    "fpRisk": { "type": ["number", "null"] },
    "fnRisk": { "type": ["number", "null"] },
    "notes": { "type": ["string", "null"] },
    "createdAt": { "type": ["string", "null"] }
  }
}
